{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run GarageApplication",
      "request": "launch",
      "mainClass": "com.gestionale.garage.GarageApplication",
      "projectName": "garage",
      "preLaunchTask": "maven-compile",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Tomcat started on port ([0-9]+)",
        "uriFormat": "http://localhost:%s"
      }
    },
    {
      "type": "java",
      "name": "Run VehicleHttpServer (legacy)",
      "request": "launch",
      "mainClass": "com.gestionale.garage.VehicleHttpServer",
      "projectName": "garage",
      "preLaunchTask": "maven-compile",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Server running on http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s"
      }
    }
  ]
}
